---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const routeDataPath = resolve('./public/data/route-data.json');
const routeDataJson = JSON.parse(readFileSync(routeDataPath, 'utf8'));
const routeMeta = routeDataJson.meta;

import BaseLayout from "../layouts/BaseLayout.astro";
import CountdownTimer from "../components/CountdownTimer.astro";
import EventInfoBlock from "../components/EventInfoBlock.astro";
import RouteMap from "../components/RouteMap.astro";
import ElevationProfile from "../components/ElevationProfile.astro";
import GravelSectors from "../components/GravelSectors.astro";
import KomSegments from "../components/KomSegments.astro";
import RestockPoints from "../components/RestockPoints.astro";
import PhotoGallery from "../components/PhotoGallery.astro";
import MkUltraExplainer from "../components/MkUltraExplainer.astro";
import GrinduroExplainer from "../components/GrinduroExplainer.astro";
import EscherLizards from "../components/EscherLizards.astro";
import TopoDivider from "../components/TopoDivider.astro";

const BIKEREG_URL = 'https://www.bikereg.com/mk-ultra-gravel';
const GLRC_URL = 'https://www.glrc.org/donate';
---

<style>
.glitch {
  color: transparent;
  position: relative;
  color: white;
}

@keyframes noise-anim {
  0% { clip-path: inset(100% 0 41% 0); }
  5% { clip-path: inset(92% 0 30% 0); }
  10% { clip-path: inset(96% 0 11% 0); }
  15% { clip-path: inset(46% 0 61% 0); }
  20% { clip-path: inset(55% 0 80% 0); }
  25% { clip-path: inset(29% 0 44% 0); }
  30% { clip-path: inset(18% 0 76% 0); }
  35% { clip-path: inset(6% 0 94% 0); }
  40% { clip-path: inset(56% 0 6% 0); }
  45% { clip-path: inset(41% 0 30% 0); }
  50% { clip-path: inset(18% 0 55% 0); }
  55% { clip-path: inset(30% 0 95% 0); }
  60% { clip-path: inset(9% 0 97% 0); }
  65% { clip-path: inset(1% 0 30% 0); }
  70% { clip-path: inset(17% 0 71% 0); }
  75% { clip-path: inset(39% 0 3% 0); }
  80% { clip-path: inset(15% 0 91% 0); }
  85% { clip-path: inset(4% 0 23% 0); }
  90% { clip-path: inset(20% 0 43% 0); }
  95% { clip-path: inset(46% 0 22% 0); }
  100% { clip-path: inset(13% 0 79% 0); }
}
.glitch:after {
  content: attr(data-text);
  position: absolute;
  left: 2px;
  right: -2px;
  top: 0;
  color: transparent;
  clip-path: inset(0 0 100% 0);
  animation: noise-anim 2s infinite linear alternate-reverse;
}

@keyframes noise-anim-2 {
  0% { clip-path: inset(14% 0 6% 0); }
  5% { clip-path: inset(17% 0 59% 0); }
  10% { clip-path: inset(19% 0 48% 0); }
  15% { clip-path: inset(100% 0 71% 0); }
  20% { clip-path: inset(96% 0 88% 0); }
  25% { clip-path: inset(95% 0 50% 0); }
  30% { clip-path: inset(15% 0 13% 0); }
  35% { clip-path: inset(96% 0 44% 0); }
  40% { clip-path: inset(63% 0 96% 0); }
  45% { clip-path: inset(5% 0 19% 0); }
  50% { clip-path: inset(24% 0 79% 0); }
  55% { clip-path: inset(50% 0 60% 0); }
  60% { clip-path: inset(72% 0 19% 0); }
  65% { clip-path: inset(67% 0 56% 0); }
  70% { clip-path: inset(95% 0 16% 0); }
  75% { clip-path: inset(76% 0 45% 0); }
  80% { clip-path: inset(39% 0 83% 0); }
  85% { clip-path: inset(47% 0 41% 0); }
  90% { clip-path: inset(50% 0 90% 0); }
  95% { clip-path: inset(53% 0 92% 0); }
  100% { clip-path: inset(25% 0 51% 0); }
}
.glitch:before {
  content: attr(data-text);
  position: absolute;
  left: -2px;
  right: 2px;
  text-shadow: 1px 0 blue;
  top: 0;
  color: white;
  clip-path: inset(0 0 100% 0);
  animation: noise-anim-2 3s infinite linear alternate-reverse;
}
</style>

<BaseLayout>
  <link
    rel="preload"
    href="/tone/CIA-MKULTRA-IG_Page_01.webp"
    as="image"
    type="image/webp"
    fetchpriority="high"
    slot="head"
  />
  <main>
    <section id="hero" class="relative min-h-screen flex items-center justify-center px-4 overflow-hidden">
      <img
        src="/tone/CIA-MKULTRA-IG_Page_01.webp"
        alt=""
        class="tone-image inset-0 w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="relative z-10 text-center max-w-3xl">
        <p class="stamp mb-6">Classification: Ultra</p>
        <svg
          class="penrose-hero mx-auto mb-4"
          aria-hidden="true"
          width="80"
          height="80"
          viewBox="0 0 280 243"
          xmlns="http://www.w3.org/2000/svg"
        >
          <g transform="translate(0, -12)">
            <path d="M 55.0625,182.4375 L 80.6875,182.5625 L 151.21875,59.84375 L 252.21615,228.15076 L 264.76729,205.25818 L 151.5625,13.25 Z" fill="#a3f0a0"/>
            <path d="M 15.625,206.0625 L 27.5,228.4375 L 252.30454,228.28334 L 151.23246,59.859344 L 138.54873,81.934334 L 211.73429,205.92661 Z" fill="#6db86a"/>
            <path d="M 124.05609,12.990601 L 15.638759,206.0253 L 211.76418,205.96833 L 197.88064,182.51185 L 54.948939,182.532 L 151.67357,13.253813 Z" fill="#3d7a3a"/>
          </g>
        </svg>
        <h1 data-text="MK Ultra Gravel" class="glitch text-5xl md:text-8xl tracking-tight mb-4">MK Ultra Gravel</h1>
        <p class="text-text-muted text-lg md:text-xl mb-2">
          June 7, 2026 &mdash; Marquette, MI
        </p>
        <p class="text-text-muted text-sm mb-6">
          Marquette Fire Bell &mdash; 100 miles &mdash; Free
        </p>

        <div class="mb-8">
          <CountdownTimer />
        </div>

        <a
          href={BIKEREG_URL}
          class="inline-block bg-accent-green text-bg-base font-bold uppercase tracking-widest
                 px-8 py-4 text-lg hover:opacity-90 transition-opacity mb-6
                 active:translate-y-px active:scale-[0.98] motion-reduce:active:transform-none"
        >
          Register Now
        </a>

        <p class="text-text-muted text-xs">
          $10 suggested donation to <a href={GLRC_URL} class="text-text-muted hover:text-accent-green transition-colors underline">Great Lakes Recovery Centers</a>
        </p>

        <p class="text-text-muted text-sm mt-6">
          Subject: <span class="redacted">mind control</span> gravel cycling
        </p>
      </div>
    </section>

    <MkUltraExplainer />

    <section id="route" class="relative min-h-screen px-4 py-16 overflow-hidden border-t border-border">
      <img
        src="/tone/escharian_stairs_fb.webp"
        alt=""
        class="tone-image inset-0 w-full h-full object-cover"
        loading="lazy"
      />
      <div class="relative z-10">
        <h2 class="text-3xl md:text-5xl mb-4" data-reveal>The Route</h2>
        <p class="text-accent-green text-xl md:text-2xl mb-8">
          {Math.floor(routeMeta.totalMi)} miles &mdash; {routeMeta.elevationGainFt.toLocaleString()} ft elevation gain
        </p>
        <RouteMap />
        <ElevationProfile />
      </div>
    </section>

    <TopoDivider />

    <div class="relative px-4 py-12 text-center border-t border-border">
      <p class="text-text-muted text-sm uppercase tracking-widest mb-4">
        Like what you see?
      </p>
      <a
        href={BIKEREG_URL}
        class="inline-block bg-accent-green text-bg-base font-bold uppercase tracking-widest
               px-8 py-4 text-lg hover:opacity-90 transition-opacity
               active:translate-y-px active:scale-[0.98] motion-reduce:active:transform-none"
      >
        Register Now
      </a>
    </div>

    <section id="sectors" class="relative min-h-screen px-4 py-16 overflow-hidden border-t border-border">
      <EscherLizards />
      <div class="relative z-10 max-w-6xl mx-auto">
        <h2 class="text-3xl md:text-5xl mb-8" data-reveal>Gravel Sectors</h2>
        <GrinduroExplainer />
        <div class="grid md:grid-cols-3 gap-8">
          <div class="md:col-span-2">
            <p class="text-text-muted text-xs uppercase tracking-widest mb-4">Paris-Roubaix Rated Sectors</p>
            <GravelSectors />
          </div>
          <div>
            <p class="text-text-muted text-xs uppercase tracking-widest mb-4">KOM Segments</p>
            <KomSegments />
            <p class="text-text-muted text-xs uppercase tracking-widest mt-8 mb-4">Restock Points</p>
            <RestockPoints />
          </div>
        </div>
      </div>
    </section>

    <TopoDivider />

    <section id="photos" class="relative min-h-screen px-4 py-16 overflow-y-hidden border-t border-border">
      <img
        src="/tone/lsd-mind-control.webp"
        alt=""
        class="tone-image inset-0 w-full h-full object-cover"
        loading="lazy"
      />
      <div class="relative z-10">
        <h2 class="text-3xl md:text-5xl mb-8" data-reveal>Route Photos</h2>
        <PhotoGallery />
      </div>
    </section>

    <section id="info" class="relative min-h-screen px-4 py-16 overflow-hidden border-t border-border">
      <img
        src="/tone/Mkultra-lsd-doc.webp"
        alt=""
        class="tone-image inset-0 w-full h-full object-cover"
        loading="lazy"
      />
      <div class="relative z-10 max-w-2xl">
        <h2 class="text-3xl md:text-5xl mb-8" data-reveal>Event Info</h2>
        <EventInfoBlock />
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  // Scroll-reveal: IntersectionObserver adds .is-visible to [data-reveal] elements
  // Centralized in index.astro — covers all [data-reveal] elements across all components
  function initReveal() {
    // Mark <html> as JS-ready so CSS applies opacity: 0 initial state
    document.documentElement.setAttribute("data-reveal-ready", "");

    // Respect prefers-reduced-motion — skip observer entirely
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      return;
    }

    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            revealObserver.unobserve(entry.target);
          }
        });
      },
      {
        rootMargin: "0px 0px -40px 0px",
        threshold: 0.05,
      }
    );

    document.querySelectorAll("[data-reveal]").forEach((el) => {
      revealObserver.observe(el);
    });
  }

  // Support Astro View Transitions
  document.addEventListener("astro:page-load", initReveal);
  // Fallback for non-View-Transitions pages
  if (!document.querySelector("[data-astro-transition]")) {
    initReveal();
  }

  // Reset button now lives inside RouteMap as a custom Leaflet control
</script>
