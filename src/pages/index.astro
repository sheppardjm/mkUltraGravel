  }
  15% {
    clip: rect(44px, 9999px, 37px, 0);
  }
  20% {
    clip: rect(53px, 9999px, 19px, 0);
  }
  25% {
    clip: rect(28px, 9999px, 54px, 0);
  }
  30% {
    clip: rect(17px, 9999px, 23px, 0);
  }
  35% {
    clip: rect(6px, 9999px, 6px, 0);
  }
  40% {
    clip: rect(54px, 9999px, 90px, 0);
  }
  45% {
    clip: rect(39px, 9999px, 67px, 0);
  }
  50% {
    clip: rect(17px, 9999px, 43px, 0);
  }
  55% {
