  }
  90% {
    clip: rect(19px, 9999px, 55px, 0);
  }
  95% {
    clip: rect(44px, 9999px, 75px, 0);
  }
  100% {
    clip: rect(12px, 9999px, 20px, 0);
  }
}
.glitch:after {
  content: attr(data-text);
  position: absolute;
  left: 2px;
  top: 0;
  color: transparent;
  overflow: hidden;
  clip: rect(0, 900px, 0, 0);
  animation: noise-anim 2s infinite linear alternate-reverse;
