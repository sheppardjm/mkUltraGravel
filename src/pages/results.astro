                                  <span class="tabular-nums" style="color: var(--color-accent-white);">{formatTime(entry.climbPoints[segId].elapsed_time)}</span>
                                  {" — "}
                                  <span style="color: var(--color-text-muted);">#{entry.climbPoints[segId].rank}</span>
                                  {" "}
                                  <span style="color: var(--color-accent-green);">({entry.climbPoints[segId].points} pts)</span>
                                </div>
