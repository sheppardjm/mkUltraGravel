                            </dl>
                          </details>
                        </td>
                        <td class="py-3 pr-4 tabular-nums font-bold" style="color: var(--color-accent-green); font-family: var(--font-mono);">
                          {entry.totalPoints}<span class="font-normal" style="color: var(--color-text-muted);">/30</span>
                        </td>
                        <td class="py-3">
                          <a
                            href={entry.activityUrl}
