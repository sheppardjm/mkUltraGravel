---
import BaseLayout from "../layouts/BaseLayout.astro";

// Check for OAuth denial redirect from strava-callback
const submitDenied = Astro.url.searchParams.get("submit") === "denied";
---

<BaseLayout title="Submit Your Results — MK Ultra Gravel">
  <main class="min-h-screen flex flex-col items-center justify-center px-4 py-16">
    <div class="w-full max-w-2xl mx-auto">

      <!-- Back link -->
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm mb-10 opacity-60 hover:opacity-100 transition-opacity"
        style="font-family: var(--font-mono);"
      >
        ← Back to MK Ultra Gravel
      </a>

      <!-- Header -->
      <h1
        class="text-4xl sm:text-5xl mb-4"
        style="font-family: var(--font-display); color: var(--color-accent-white);"
      >
        Submit Your Results
      </h1>

      <p class="mb-8 text-base leading-relaxed" style="color: var(--color-text-muted);">
        Paste your Strava activity URL below to submit your segment times for scoring.
        You'll be redirected to Strava to authorize access to your activity.
      </p>

      <!-- OAuth denial alert -->
      {submitDenied && (
        <div
          id="denial-alert"
          role="alert"
          class="mb-6 flex items-start gap-3 rounded border px-4 py-3 text-sm"
          style="border-color: var(--color-accent-red); background-color: oklch(0.14 0.06 25); color: oklch(0.85 0.01 90);"
        >
          <span class="mt-0.5 shrink-0" aria-hidden="true">!</span>
          <span>
            Strava authorization was denied. Please try again.
          </span>
          <button
            type="button"
            onclick="document.getElementById('denial-alert').remove()"
            class="ml-auto shrink-0 opacity-60 hover:opacity-100 transition-opacity"
            aria-label="Dismiss"
          >
            ×
          </button>
        </div>
      )}

      <!-- Form card -->
      <div
        class="rounded-lg border p-6 sm:p-8"
        style="background-color: var(--color-bg-surface); border-color: var(--color-border);"
      >
        <form id="submit-form" action="/api/strava-auth" method="GET" novalidate>
          <label
            for="activityUrl"
            class="block text-xs uppercase tracking-widest mb-2"
            style="font-family: var(--font-mono); color: var(--color-text-muted);"
          >
            Strava Activity URL
          </label>

          <input
            id="activityUrl"
            name="activityUrl"
            type="url"
            placeholder="https://www.strava.com/activities/12345678"
            required
            autocomplete="off"
            spellcheck="false"
            class="w-full rounded border px-4 py-3 text-sm outline-none transition-colors mb-2"
            style="
              background-color: var(--color-bg-elevated);
              border-color: var(--color-border);
              color: var(--color-accent-white);
              font-family: var(--font-mono);
            "
          />

          <!-- Inline validation error -->
          <p
            id="url-error"
            role="alert"
            class="hidden text-xs mb-4"
            style="color: var(--color-accent-red); font-family: var(--font-mono);"
          >
            Please enter a valid Strava activity URL (e.g. https://www.strava.com/activities/12345678)
          </p>

          <div class="mt-6">
            <button
              type="submit"
              class="w-full rounded px-6 py-3 text-sm font-bold uppercase tracking-widest transition-opacity hover:opacity-90 active:opacity-75"
              style="
                background-color: oklch(0.72 0.19 55);
                color: oklch(0.10 0.01 250);
                font-family: var(--font-mono);
              "
            >
              Connect with Strava
            </button>
          </div>

          <p class="mt-4 text-xs text-center" style="color: var(--color-text-muted); font-family: var(--font-mono);">
            You'll be asked to authorize read access to your Strava activities.
            No data is stored beyond your segment times.
          </p>

          <p class="mt-2 text-xs text-center" style="color: var(--color-text-muted); font-family: var(--font-mono);">
            Your segment times are stored publicly on the results page. You may revoke
            access at any time via your
            <a href="https://www.strava.com/settings/apps" target="_blank" rel="noopener noreferrer"
               style="color: oklch(0.72 0.19 55);">Strava settings</a>
            — your data will be deleted within 48 hours of deauthorization.
          </p>
        </form>
      </div>

    </div>
  </main>

  <script>
    // Client-side validation: intercept form submission, validate URL format,
    // then redirect manually so we can control the query param encoding.
    const form = document.getElementById('submit-form') as HTMLFormElement;
    const input = document.getElementById('activityUrl') as HTMLInputElement;
    const errorEl = document.getElementById('url-error') as HTMLParagraphElement;

    // Highlight input on focus/blur to match the dark theme
    input.addEventListener('focus', () => {
      input.style.borderColor = 'oklch(0.72 0.19 55)';
    });
    input.addEventListener('blur', () => {
      input.style.borderColor = 'var(--color-border)';
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const url = input.value.trim();
      const stravaActivityPattern = /strava\.com\/activities\/\d+/;

      if (!url || !stravaActivityPattern.test(url)) {
        errorEl.classList.remove('hidden');
        input.style.borderColor = 'var(--color-accent-red)';
        input.focus();
        return;
      }

      // Clear any previous error
      errorEl.classList.add('hidden');
      input.style.borderColor = 'oklch(0.72 0.19 55)';

      // Redirect to strava-auth function with the validated activity URL
      window.location.href = `/api/strava-auth?activityUrl=${encodeURIComponent(url)}`;
    });

    // Clear error as user types
    input.addEventListener('input', () => {
      if (!errorEl.classList.contains('hidden')) {
        errorEl.classList.add('hidden');
        input.style.borderColor = 'var(--color-border)';
      }
    });
  </script>
</BaseLayout>
