---
// ElevationProfile.astro — Chart.js canvas elevation profile with sector band overlays
// Dynamic imports in <script> prevent SSR "window is undefined" errors (same pattern as RouteMap.astro)
---

<div class="elevation-wrapper">
  <div class="elevation-container">
    <canvas id="elevation-chart"></canvas>
  </div>
</div>

<style>
  .elevation-wrapper {
    width: 100%;
    margin-top: 0.5rem;
  }

  /* Wrapper controls height — Chart.js sizes canvas to fill it */
  /* REQUIRED: position: relative for Chart.js responsive mode */
  .elevation-container {
    position: relative;
    width: 100%;
    height: 140px;
  }

  @media (min-width: 768px) {
    .elevation-container {
      height: 180px;
    }
  }
</style>

<script>
  // IntersectionObserver-based lazy init — Chart.js + route-data only load when chart scrolls into view.
  // Defers 70KB (chart.js) + 44KB (route-data.json) off the LCP critical path.
  async function initElevation() {
  // Dynamic import avoids SSR "window is undefined" error — Chart.js requires browser globals
  const { Chart } = await import('chart.js/auto');
  // AnnotationPlugin must be registered BEFORE new Chart() — silent failure otherwise
  const { default: AnnotationPlugin } = await import('chartjs-plugin-annotation');
  Chart.register(AnnotationPlugin);
  const { getRelativePosition } = await import('chart.js/helpers');

  // Parallel fetch — established Promise.all pattern from RouteMap.astro
  const [routeJson, annotations] = await Promise.all([
    fetch('/data/route-data.json').then(r => r.json()),
    fetch('/data/annotations.json').then(r => r.json())
  ]);
  const routeData = routeJson.track ?? routeJson;
  const totalMi = routeJson.meta?.totalMi ?? routeData[routeData.length - 1]?.mi ?? 110;

  // Map to {x, y} shape required by parsing: false mode (decimation requires this)
  const chartData = routeData.map((pt: { mi: number; ele: number }) => ({
    x: pt.mi,
    y: pt.ele
  }));

  // Sector band color scale — matches map's starColors
  const starColors: Record<number, string> = {
    1: '#f0c040',
    2: '#e8962a',
    3: '#d9641e',
    4: '#c93a18',
    5: '#b71c1c'
  };

  // Build sector band annotation boxes from annotations.json sectors
  const annotationBoxes: Record<string, object> = {};
  annotations.sectors.forEach((sector: { name: string; startMi: number; endMi: number; stars: number }, i: number) => {
    annotationBoxes[`sector_${i}`] = {
      type: 'box',
      xMin: sector.startMi,
      xMax: sector.endMi,
      backgroundColor: starColors[sector.stars] + '22',  // ~13% opacity fill
      borderColor: starColors[sector.stars] + '66',       // ~40% opacity border
      borderWidth: 1,
      _baseColor: starColors[sector.stars],               // stored for highlight/restore
      click: () => {
        window.dispatchEvent(new CustomEvent('elevation:sectorClick', {
          detail: { sectorIndex: i }
        }));
      },
    };
  });

  // Build KOM segment annotation boxes — chartreuse to match map KOM polylines (#7fff00)
  annotations.kom.forEach((kom: { name: string; startMi: number; endMi: number }, i: number) => {
    annotationBoxes[`kom_${i}`] = {
      type: 'box',
      drawTime: 'beforeDatasetsDraw',
      xMin: kom.startMi,
      xMax: kom.endMi,
      backgroundColor: '#7fff0018',   // chartreuse ~9% opacity — subtle beneath line
      borderColor: '#7fff0055',       // chartreuse ~33% opacity border
      borderWidth: 1,
      borderDash: [6, 3],             // dashed border — matches map KOM dashArray style
      label: {
        display: true,
        content: kom.name,
        color: '#7fff00cc',           // chartreuse ~80% opacity text
        font: { size: 9, family: 'Space Mono, monospace' },
        position: 'start',
      },
    };
  });

  // Canvas background plugin — matches --color-bg-surface (oklch dark palette)
  const darkBgPlugin = {
    id: 'darkBackground',
    beforeDraw: (chart: any) => {
      const { ctx } = chart;
      ctx.save();
      ctx.globalCompositeOperation = 'destination-over';
      ctx.fillStyle = 'oklch(0.14 0.01 250)';
      ctx.fillRect(0, 0, chart.width, chart.height);
      ctx.restore();
    }
  };

  // Binary search for nearest track point by mile value — O(log n) per hover event
  function findNearestTrackPoint(
    track: {lat: number; lon: number; mi: number}[],
    mile: number
  ): {lat: number; lon: number; mi: number} | null {
    if (!track.length) return null;
    let lo = 0, hi = track.length - 1;
    while (lo < hi) {
      const mid = (lo + hi) >> 1;
      if (track[mid].mi < mile) lo = mid + 1;
      else hi = mid;
    }
    if (lo > 0 && Math.abs(track[lo-1].mi - mile) < Math.abs(track[lo].mi - mile)) {
      return track[lo-1];
    }
    return track[lo];
  }

  // rAF throttle — prevents queuing multiple animation frames on rapid mouse movement
  let rafPending = false;

  // Null guard — module scripts defer until DOM is ready, but guard defensively
  // Note: top-level return is not valid in ESM modules — use conditional block instead
  const canvas = document.getElementById('elevation-chart') as HTMLCanvasElement;
  const chartInstance = canvas ? new Chart(canvas, {
    type: 'line',
    data: {
      datasets: [{
        data: chartData,
        borderColor: 'oklch(0.55 0.01 90)',
        borderWidth: 1.5,
        backgroundColor: 'oklch(0.25 0.01 250 / 0.4)',
        fill: true,
        tension: 0,
        pointRadius: 0,
      }]
    },
    options: {
      parsing: false,       // data is pre-parsed {x, y} — required for decimation
      animation: false,     // static chart — no entry animation
      responsive: true,
      maintainAspectRatio: false,  // REQUIRED: wrapper div controls height
      onHover: (event: any, _activeElements: any, chart: any) => {
        if (rafPending) return;
        rafPending = true;
        requestAnimationFrame(() => {
          rafPending = false;
          if (!event.native) return;
          const canvasPos = getRelativePosition(event.native, chart);
          const mile = chart.scales.x.getValueForPixel(canvasPos.x);
          if (mile == null) return;
          const pt = findNearestTrackPoint(routeData, mile);
          if (pt) {
            window.dispatchEvent(new CustomEvent('elevation:hover', {
              detail: { lat: pt.lat, lon: pt.lon }
            }));
          }
        });
      },
      plugins: {
        legend: { display: false },
        decimation: {
          enabled: true,
          algorithm: 'lttb',   // Largest Triangle Three Bucket — preserves peaks/valleys
          samples: 500
        },
        annotation: { annotations: annotationBoxes },
        tooltip: {
          callbacks: {
            label: (ctx) => `${Math.round((ctx.parsed.y as number) * 3.281)} ft`,
            title: (items) => `${(items[0].parsed.x as number).toFixed(1)} mi`
          }
        }
      },
      scales: {
        x: {
          type: 'linear',
          min: 0,
          max: Math.ceil(totalMi),
          grid: { color: 'oklch(0.25 0.01 250)' },
          ticks: {
            color: 'oklch(0.55 0.01 90)',
            callback: (val) => `${val}mi`
          }
        },
        y: {
          grid: { color: 'oklch(0.25 0.01 250)' },
          ticks: {
            color: 'oklch(0.55 0.01 90)',
            callback: (val) => `${Math.round((val as number) * 3.281)}ft`  // meters → feet
          }
        }
      }
    },
    plugins: [darkBgPlugin]  // registered here (Chart constructor array), not in options.plugins
  }) : null;

  // Dispatch elevation:hoverEnd when cursor leaves the chart canvas
  if (canvas) {
    canvas.addEventListener('mouseleave', () => {
      window.dispatchEvent(new CustomEvent('elevation:hoverEnd'));
    });
  }

  // AbortController for cleanup — removes window listeners when page unloads
  const controller = new AbortController();
  const { signal } = controller;
  window.addEventListener('beforeunload', () => controller.abort(), { once: true });

  // Listen for map:sectorHover — highlight the hovered sector's annotation band
  window.addEventListener('map:sectorHover', ((e: Event) => {
    const { sectorIndex } = (e as CustomEvent<{sectorIndex: number | null}>).detail;
    const annots = (chartInstance as any).options.plugins.annotation.annotations;
    Object.keys(annots).forEach(key => {
      const annot = annots[key];
      if (annot._baseColor) {
        annot.backgroundColor = annot._baseColor + '22';
        annot.borderColor = annot._baseColor + '66';
      }
    });
    if (sectorIndex !== null) {
      const key = `sector_${sectorIndex}`;
      if (annots[key] && annots[key]._baseColor) {
        annots[key].backgroundColor = annots[key]._baseColor + '66';
        annots[key].borderColor = annots[key]._baseColor + 'aa';
      }
    }
    (chartInstance as any).update('none');
  }) as EventListener, { signal });

  // Listen for map:reset — restore all sector annotation bands to default opacity
  window.addEventListener('map:reset', (() => {
    const annots = (chartInstance as any).options.plugins.annotation.annotations;
    Object.keys(annots).forEach(key => {
      const annot = annots[key];
      if (annot._baseColor) {
        annot.backgroundColor = annot._baseColor + '22';  // default ~13% opacity
        annot.borderColor = annot._baseColor + '66';       // default ~40% opacity
      }
    });
    (chartInstance as any).update('none');
  }) as EventListener, { signal });

  // Listen for map:sectorClick — dim all other sectors, strongly highlight the clicked one
  window.addEventListener('map:sectorClick', ((e: Event) => {
    const { sectorIndex } = (e as CustomEvent<{sectorIndex: number}>).detail;
    const annots = (chartInstance as any).options.plugins.annotation.annotations;
    Object.keys(annots).forEach(key => {
      const annot = annots[key];
      if (annot._baseColor) {
        annot.backgroundColor = annot._baseColor + '15';
        annot.borderColor = annot._baseColor + '33';
      }
    });
    const key = `sector_${sectorIndex}`;
    if (annots[key] && annots[key]._baseColor) {
      annots[key].backgroundColor = annots[key]._baseColor + '88';
      annots[key].borderColor = annots[key]._baseColor + 'cc';
    }
    (chartInstance as any).update('none');
  }) as EventListener, { signal });
  } // end initElevation

  // Defer Chart.js loading until user scrolls (same pattern as RouteMap).
  // Scroll event fires on first scroll; IntersectionObserver with 0 rootMargin for anchor nav.
  let elevationInitialized = false;
  const chartCanvas = document.getElementById('elevation-chart');

  function tryInitElevation() {
    if (!elevationInitialized) {
      elevationInitialized = true;
      initElevation();
    }
  }

  if (chartCanvas) {
    window.addEventListener('scroll', tryInitElevation, { once: true, passive: true });

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          observer.disconnect();
          tryInitElevation();
        }
      },
      { rootMargin: '0px' }
    );
    observer.observe(chartCanvas);
  }
</script>
