---
import { readFileSync } from "fs";
import { join } from "path";

const raw = readFileSync(join(process.cwd(), "public", "data", "annotations.json"), "utf-8");
const annotations = JSON.parse(raw);
const restock = annotations.restock as Array<{
  name: string;
  mi: number;
}>;
---

<ul class="space-y-3">
  {restock.map((point) => (
    <li class="flex items-center gap-3 text-text-body text-sm">
      <span class="text-accent-green" aria-hidden="true">&#9658;</span>
      <span>{point.name}</span>
      <span class="text-text-muted ml-auto">Mile {point.mi}</span>
    </li>
  ))}
</ul>
