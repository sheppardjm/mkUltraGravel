---
import fs from 'node:fs';
import path from 'node:path';

const photosRaw = fs.readFileSync(path.join(process.cwd(), 'public/data/photos.json'), 'utf-8');
const photos = JSON.parse(photosRaw) as Array<{
  filename: string;
  mi: number;
  width: number;
  height: number;
}>;
---

<div id="photo-gallery" class="masonry-gallery">
  {photos.map((photo) => {
    const thumbFilename = photo.filename.replace(/\.(jpg|jpeg|png|avif)$/i, '.webp');
    // Thumbs are generated at 400px wide; compute proportional height
    const thumbWidth = 400;
    const thumbHeight = Math.round(400 * (photo.height / photo.width));
    return (
      <a
        href={`/images/${photo.filename}`}
        data-pswp-width={photo.width}
        data-pswp-height={photo.height}
        class="gallery-item"
        style={`aspect-ratio: ${photo.width} / ${photo.height};`}
        aria-label={`View route photo at mile ${photo.mi}`}
      >
        <img
          src={`/images/thumbs/${thumbFilename}`}
          alt={`Route photo at mile ${photo.mi}`}
          width={thumbWidth}
          height={thumbHeight}
          loading="lazy"
          decoding="async"
          class="gallery-img"
        />
        <span class="gallery-mile">mi {photo.mi}</span>
      </a>
    );
  })}
</div>

<style>
  .masonry-gallery {
    columns: 2 160px;
    column-gap: 6px;
    max-height: 75vh;
    overflow-x: auto;
    overflow-y: hidden;
    column-fill: auto;
  }

  @media (min-width: 480px) {
    .masonry-gallery {
      columns: 3 180px;
      max-height: 80vh;
    }
  }

  @media (min-width: 768px) {
    .masonry-gallery {
      columns: 4 200px;
      column-gap: 8px;
      max-height: 90vh;
    }
  }

  @media (min-width: 1280px) {
    .masonry-gallery {
      columns: 5 220px;
      max-height: 95vh;
    }
  }

  .gallery-item {
    display: block;
    break-inside: avoid;
    margin-bottom: 6px;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    /* Reserve space before image loads — color shows as placeholder */
    background-color: #27272a; /* zinc-800 */
    width: 100%;
  }

  @media (min-width: 768px) {
    .gallery-item {
      margin-bottom: 8px;
    }
  }

  .gallery-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.2s ease;
  }

  .gallery-item:hover .gallery-img {
    opacity: 0.85;
  }

  .gallery-mile {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 4px 6px;
    font-size: 0.65rem;
    font-family: var(--font-mono, monospace);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.75);
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.55));
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .gallery-item:hover .gallery-mile {
    opacity: 1;
  }
</style>

<script>
import PhotoSwipeLightbox from 'photoswipe/lightbox';

function initGallery() {
  const gallery = document.getElementById('photo-gallery');
  if (!gallery) return;

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#photo-gallery',
    children: '.gallery-item',
    pswpModule: () => import('photoswipe'),
    bgOpacity: 0.95,
  });
  lightbox.init();
}

// Support Astro View Transitions
document.addEventListener('astro:page-load', initGallery);
// Fallback for non-View-Transitions pages
if (!document.querySelector('[data-astro-transition]')) {
  initGallery();
}
</script>
