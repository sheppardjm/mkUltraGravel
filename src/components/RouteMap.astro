---
// RouteMap.astro — Leaflet interactive map with Carto Dark Matter tiles and GPX route polyline
// Dynamic imports in <script> prevent SSR "window is undefined" errors (Pitfall 1)
// Leaflet CSS is imported via global.css in @layer leaflet (not here)
---

<div id="map" class="route-map"></div>

<style>
  .route-map {
    width: 100%;
    height: 60vh;
    min-height: 400px;
    position: relative;
    z-index: 0;
  }

  /* Leaflet appends divIcon elements outside the component scope — :global() required */
  :global(.restock-marker) {
    background: transparent !important;
    border: none !important;
  }

  :global(.photo-marker) {
    background: transparent !important;
    border: none !important;
  }

  :global(.photo-cluster) {
    background: transparent !important;
    border: none !important;
  }
</style>

<script>
  // Dynamic import avoids SSR "window is undefined" error — Leaflet requires browser globals
  const L = (await import('leaflet')).default;

  // Wire GestureHandling BEFORE map init — addInitHook must be called before L.map()
  const { GestureHandling } = await import('leaflet-gesture-handling');
  L.Map.addInitHook('addHandler', 'gestureHandling', GestureHandling);

  // markercluster — side-effect import; attaches L.markerClusterGroup() to window.L
  await import('leaflet.markercluster');

  // Initialize map with gestureHandling enabled
  const map = L.map('map', { gestureHandling: true });

  // Carto Dark Matter tiles — no API key required
  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
    subdomains: 'abcd',
    maxZoom: 20
  }).addTo(map);

  // Fetch route data, annotations, and photos in parallel
  const [routeData, annotations, photos] = await Promise.all([
    fetch('/data/route-data.json').then(r => r.json()),
    fetch('/data/annotations.json').then(r => r.json()),
    fetch('/data/photos.json').then(r => r.json())
  ]);
  const latlngs = routeData.map((pt: { lat: number; lon: number }) => [pt.lat, pt.lon] as [number, number]);
  const routeLine = L.polyline(latlngs, {
    color: '#d4d4d4',
    weight: 3,
    opacity: 0.7,
    smoothFactor: 1
  }).addTo(map);

  // Auto-fit map to the full route bounds
  map.fitBounds(routeLine.getBounds(), { padding: [20, 20] });

  // Star-rating color scale — brutalist palette
  const starColors: Record<number, string> = {
    1: '#888888',   // light gravel — muted gray
    2: '#aaaaaa',   // moderate — lighter gray
    3: '#f5a623',   // amber — getting rough
    4: '#e86d1f',   // orange — hard
    5: '#c0392b'    // red — brutal
  };

  // Render gravel sector overlays
  const sectorBadges = L.layerGroup();

  annotations.sectors.forEach((sector: { name: string; stars: number; lengthMi: number; track: { lat: number; lon: number }[] }) => {
    const sectorLatlngs = sector.track.map((pt) => [pt.lat, pt.lon] as [number, number]);
    L.polyline(sectorLatlngs, {
      color: starColors[sector.stars] || '#ffffff',
      weight: 5,
      opacity: 0.9
    })
    .bindPopup(
      `<strong>${sector.name}</strong><br>` +
      `${'★'.repeat(sector.stars)}${'☆'.repeat(5 - sector.stars)}<br>` +
      `${sector.lengthMi.toFixed(1)} mi`,
      { className: 'dark-popup' }
    )
    .addTo(map);

    // Persistent star-rating badge at sector midpoint
    const mid = Math.floor(sector.track.length / 2);
    const midPt = sector.track[mid];
    const starStr = '★'.repeat(sector.stars) + '☆'.repeat(5 - sector.stars);
    const badge = L.marker([midPt.lat, midPt.lon], {
      icon: L.divIcon({
        className: 'sector-badge',
        html: `<span style="color:${starColors[sector.stars] || '#ffffff'}">${starStr}</span>`,
        iconSize: [null, null] as any,
        iconAnchor: [0, 0]
      }),
      interactive: false
    });
    sectorBadges.addLayer(badge);
  });

  // Show sector badges only at zoom 10+
  function updateBadgeVisibility() {
    if (map.getZoom() >= 10) {
      if (!map.hasLayer(sectorBadges)) map.addLayer(sectorBadges);
    } else {
      if (map.hasLayer(sectorBadges)) map.removeLayer(sectorBadges);
    }
  }
  map.on('zoomend', updateBadgeVisibility);
  updateBadgeVisibility(); // initial check

  // Render KOM overlays — dashed chartreuse green, distinct from sector colors
  annotations.kom.forEach((kom: { name: string; grade: number; elevFt: number; lengthMi: number; track: { lat: number; lon: number }[] }) => {
    const komLatlngs = kom.track.map((pt) => [pt.lat, pt.lon] as [number, number]);
    L.polyline(komLatlngs, {
      color: '#7fff00',
      weight: 6,
      opacity: 0.85,
      dashArray: '8, 4'
    })
    .bindPopup(
      `<strong>${kom.name}</strong><br>` +
      `Grade: ${kom.grade}%<br>` +
      `Elevation: ${kom.elevFt} ft<br>` +
      `${kom.lengthMi.toFixed(1)} mi`,
      { className: 'dark-popup' }
    )
    .addTo(map);
  });

  // Render restock point markers — cyan divIcon avoids broken default icon paths in Vite builds
  annotations.restock.forEach((stop: { name: string; mi: number; lat: number; lon: number }) => {
    const icon = L.divIcon({
      className: 'restock-marker',
      html: '<div style="width:12px;height:12px;background:#22d3ee;border:2px solid #fff;border-radius:50%;"></div>',
      iconSize: [16, 16],
      iconAnchor: [8, 8],
      popupAnchor: [0, -10]
    });

    L.marker([stop.lat, stop.lon], { icon })
      .bindPopup(`<strong>${stop.name}</strong><br>Mile ${stop.mi}`, { className: 'dark-popup' })
      .addTo(map);
  });

  // Photo markers with clustering — MAP-06: geolocated photos are the primary differentiator
  const photoIcon = L.divIcon({
    className: 'photo-marker',
    html: '<div style="width:10px;height:10px;background:#22d3ee;border:2px solid #fff;border-radius:2px;"></div>',
    iconSize: [14, 14],
    iconAnchor: [7, 7],
    popupAnchor: [0, -10]
  });

  const photoMarkers = photos.map((photo: { filename: string; lat: number; lon: number }) =>
    L.marker([photo.lat, photo.lon], { icon: photoIcon })
      .bindPopup(
        `<a href="/images/${photo.filename}" target="_blank" rel="noopener">` +
        `<img src="/images/${photo.filename}" width="260" style="display:block;border-radius:2px;" loading="lazy">` +
        `</a>`,
        { className: 'dark-popup', maxWidth: 300 }
      )
  );

  const photoCluster = (L as any).markerClusterGroup({
    maxClusterRadius: 60,
    spiderfyOnMaxZoom: true,
    showCoverageOnHover: false,
    zoomToBoundsOnClick: true,
    iconCreateFunction: (cluster: any) => {
      const count = cluster.getChildCount();
      return L.divIcon({
        className: 'photo-cluster',
        html: `<div style="width:32px;height:32px;background:oklch(0.18 0.01 250);border:2px solid #22d3ee;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;color:#22d3ee;font-family:monospace;">${count}</div>`,
        iconSize: [32, 32],
        iconAnchor: [16, 16]
      });
    }
  });

  photoCluster.addLayers(photoMarkers);
  map.addLayer(photoCluster);
</script>
